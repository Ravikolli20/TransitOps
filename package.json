import { Controller, Get, Query } from '@nestjs/common';
import { DashboardService } from './dashboard.service';
import { DashboardQueryDto } from './dto/dashboard-query.dto';

// No @Roles() restriction here — every authenticated role gets a dashboard view,
// matching the spec's "Analytics" nav item being visible to all roles. Per-widget
// data sensitivity (e.g. revenue) can be trimmed at the frontend layer per role
// if needed later; the KPI numbers themselves aren't secret operational data.
@Controller({ path: 'dashboard', version: '1' })
export class DashboardController {
  constructor(private dashboardService: DashboardService) {}

  @Get('kpis')
  getKpis(@Query() query: DashboardQueryDto) {
    return this.dashboardService.getKpis(query);
  }

  @Get('charts')
  getCharts(@Query() query: DashboardQueryDto) {
    return this.dashboardService.getCharts(query);
  }
}
